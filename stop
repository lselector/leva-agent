#!/usr/bin/env bash
# Stop Leva Rust servers (ports 8000 & 8001)
# Usage: ./stop

killed=0

pids_8000=$(lsof -ti:8000 2>/dev/null || true)
if [ -n "$pids_8000" ]; then
    echo "Killing server_llm (port 8000)..."
    kill $pids_8000 2>/dev/null || true
    killed=1
fi

pids_8001=$(lsof -ti:8001 2>/dev/null || true)
if [ -n "$pids_8001" ]; then
    echo "Killing server_auto (port 8001)..."
    kill $pids_8001 2>/dev/null || true
    killed=1
fi

if [ "$killed" -eq 1 ]; then
    sleep 1
    echo "Leva stopped."
else
    echo "No Leva processes found."
fi
