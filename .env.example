# Non-sensitive defaults only. Secrets (API keys, OAuth tokens) must be set
# in $LEVA_AGENT_PRIV_DIR/.env (leva-agent-priv/.env) or shell environment.

# LLM provider (always anthropic)
LLM_PROVIDER=anthropic

# Model to use (optional — default shown)
# MODEL_NAME=claude-opus-4-6

# Server ports (optional — defaults shown)
# LLM_PORT=8000
# AUTO_PORT=8001

# ── Secrets (set in leva-agent-priv/.env or shell, NOT here) ─────────────
# ANTHROPIC_API_KEY=sk-ant-...
# PERPLEXITY_API_KEY=pplx-...
# Gmail OAuth credentials and tokens live in leva-agent-priv/credentials/
