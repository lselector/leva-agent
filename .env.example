# All variables here can alternatively be set in your shell environment.
# This file is optional — if it doesn't exist the app reads from the shell.

# LLM (required — set in shell or here)
# OPENAI_API_KEY=sk-...

# Model to use (optional — default shown)
# MODEL_NAME=gpt-4.1-mini

# Server ports (optional — defaults shown)
# LLM_PORT=8000
# AUTO_PORT=8001

# Web research fallback (optional)
# PERPLEXITY_API_KEY=pplx-...
