#!/usr/bin/env bash
# Start Leva (Rust version).
#
# Usage:
#   ./start        — web UI (both servers)
#   ./start cli    — CLI REPL

set -e
cd "$(dirname "$0")"

# Use release build if available, otherwise debug
BIN_DIR=target/release
if [ ! -d "$BIN_DIR" ] || [ ! -f "$BIN_DIR/server_llm" ]; then
    BIN_DIR=target/debug
fi
if [ ! -f "$BIN_DIR/server_llm" ]; then
    echo "Binaries not found. Run ./setup first."
    exit 1
fi

# Export LEVA_BASE_DIR so the Rust code finds frontend/, soul/, etc.
export LEVA_BASE_DIR="$(pwd)"

if [ "${1}" = "cli" ]; then
    # Start server_auto in background if not already running
    if ! lsof -i :8001 -sTCP:LISTEN -t &>/dev/null; then
        echo "Starting Server Auto on http://localhost:8001"
        "$BIN_DIR/server_auto" &
        SERVER_AUTO_PID=$!
        trap "kill $SERVER_AUTO_PID 2>/dev/null" EXIT INT TERM
    fi
    exec "$BIN_DIR/leva-cli"
fi

# Start both servers
echo "Starting Server LLM  on http://localhost:8000"
echo "Starting Server Auto on http://localhost:8001"
"$BIN_DIR/server_auto" &
SERVER_AUTO_PID=$!
"$BIN_DIR/server_llm" &
SERVER_LLM_PID=$!

trap "kill $SERVER_AUTO_PID $SERVER_LLM_PID 2>/dev/null" EXIT INT TERM

echo "Open http://localhost:8000 in your browser"
echo "Press Ctrl+C to stop."
wait
