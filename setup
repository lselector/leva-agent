#!/usr/bin/env bash
# Set up Leva after a fresh clone.
# Run once before ./start
#
# Usage:  ./setup

set -e
cd "$(dirname "$0")"

# ── 1. Check dependencies ─────────────────────────────────────────────────────
if ! command -v cargo &>/dev/null; then
    echo "ERROR: cargo not found. Install Rust first:"
    echo "  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh"
    exit 1
fi

# ── 2. Create required runtime directories ────────────────────────────────────
mkdir -p memory/sessions memory/topics reference credentials
echo "Created runtime directories (memory/sessions, memory/topics, reference, credentials)"

# ── 3. Build ─────────────────────────────────────────────────────────────────
echo ""
echo "Building Leva (Rust)..."
cargo build --release

echo ""
echo "Done."
echo ""
echo "Next steps:"
echo "  1. Ensure OPENAI_API_KEY is set in your shell (or create .env from .env.example)"
echo "  2. ./start"
echo ""
echo "Optional — Gmail integration only:"
echo "  Place your Gmail OAuth credentials in credentials/"
echo "  See README.md for details"
