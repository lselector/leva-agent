#!/usr/bin/env bash
# Build the Rust project (downloads deps + compiles all crates).
#
# Usage:  ./setup

set -e
cd "$(dirname "$0")"

if ! command -v cargo &>/dev/null; then
    echo "ERROR: cargo not found. Install Rust first:"
    echo "  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh"
    exit 1
fi

echo "Building Jarvis (Rust)..."
cargo build --release

echo ""
echo "Done. Next steps:"
echo "  1. Copy and edit your API key:  cp ../.env.example .env  (or copy from parent)"
echo "  2. Start Jarvis:                ./start"
